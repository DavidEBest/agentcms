# AI
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_PATH=agentcms.db

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=AgentCMS <noreply@yourdomain.com>

# S3-compatible storage (Cloudflare R2 or AWS S3)
