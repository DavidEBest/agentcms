# Database
DATABASE_PATH=agentcms.db

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=AgentCMS <noreply@yourdomain.com>

# S3-compatible storage (Cloudflare R2 or AWS S3)
S3_REGION=auto
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET=agentcms
S3_PUBLIC_URL=https://assets.yourdomain.com
